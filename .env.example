# Porta do servidor
PORT=3000

# Senha do painel administrativo (texto puro só neste .env, nunca no código)
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o token de login do admin (qualquer string longa e aleatória)
JWT_SECRET=troque-por-uma-string-aleatoria-bem-grande

# Credenciais do Mercado Pago (conta do restaurante)
# Pegue em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI

# URL pública do site depois de publicado (usada para redirecionar o cliente após o pagamento)
PUBLIC_URL=http://localhost:3000

# --- Notificações por Telegram (cozinha e entregador) ---
# Crie um bot com o @BotFather no Telegram para pegar o token, e converse com
# o @userinfobot (ou @get_id_bot) — ou adicione o bot num grupo — para
# descobrir o CHAT_ID de quem vai receber os avisos.
TELEGRAM_BOT_TOKEN=
# Chat que recebe o aviso de pedido pago (para a cozinha começar a preparar)
TELEGRAM_CHAT_ID_COZINHA=
# Chat que recebe os dados de entrega quando o pedido sai (se deixar em
# branco, usa o mesmo chat da cozinha)
TELEGRAM_CHAT_ID_ENTREGA=
